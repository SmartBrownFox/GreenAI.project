=3D"S4.SS2.SSS4.Px3.p7.1.m1" class=3D"ltx_math_unparsed" alttext=3D"\max M_=
{T}(x)!\geq!\tau" display=3D"inline" intent=3D":literal"><semantics><mrow><=
mi>max</mi><msub><mi>M</mi><mi>T</mi></msub><mrow><mo stretchy=3D"false">(<=
/mo><mi>x</mi><mo stretchy=3D"false">)</mo></mrow><mo>!</mo><mo>=E2=89=A5</=
