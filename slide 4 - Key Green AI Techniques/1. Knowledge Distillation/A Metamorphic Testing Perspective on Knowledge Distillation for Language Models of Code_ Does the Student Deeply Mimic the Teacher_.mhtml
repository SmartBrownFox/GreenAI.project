limits=3D"false" rspace=3D"0em">=E2=88=91</mo><mrow><mi>i</mi><mo>=3D</mo><=
mn>1</mn></mrow><mi>B</mi></munderover><mrow><mo rspace=3D"0.170em">|</mo><=
mrow><msubsup><mtext>acc</mtext><mi>i</mi><mtext>orig</mtext></msubsup><mo>=
=E2=88=92</mo><msubsup><mtext>acc</mtext><mi>i</mi><mtext>comp</mtext></msu=
bsup></mrow><mo>|</mo></mrow></mrow></mrow></mrow><annotation encoding=3D"a=
pplication/x-tex">\mathrm{ECA}\;=3D\;\frac{1}{B}\sum_{i=3D1}^{B}\left|\,\te=
xt{acc}^{\text{orig}}_{i}-\text{acc}^{\text{comp}}_{i}\right|</annotation><=
/semantics></math></td>
