"ltx_Math" alttext=3D"\mathbf{p}_{i}=3D[p_{i,1},p_{i,2},\ldots,p_{i,N}],\qu=
ad\sum_{j=3D1}^{N}p_{i,j}=3D1," display=3D"block" intent=3D":literal"><sema=
ntics><mrow><mrow><mrow><msub><mi>=F0=9D=90=A9</mi><mi>i</mi></msub><mo>=3D=
</mo><mrow><mo stretchy=3D"false">[</mo><msub><mi>p</mi><mrow><mi>i</mi><mo=
>,</mo><mn>1</mn></mrow></msub><mo>,</mo><msub><mi>p</mi><mrow><mi>i</mi><m=
o>,</mo><mn>2</mn></mrow></msub><mo>,</mo><mi mathvariant=3D"normal">=E2=80=
=A6</mi><mo>,</mo><msub><mi>p</mi><mrow><mi>i</mi><mo>,</mo><mi>N</mi></mro=
w></msub><mo stretchy=3D"false">]</mo></mrow></mrow><mo rspace=3D"1.000em">=
